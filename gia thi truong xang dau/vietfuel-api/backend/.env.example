# ============================================================
# Vietnam Fuel API - Environment Variables
# Copy file này thành .env để cấu hình server
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Cache ---
# Thời gian giữ cache trong bộ nhớ (phút). Mặc định: 60
CACHE_TTL_MINUTES=60

# --- Cron Job ---
# Lịch tự động cào dữ liệu. Mặc định: mỗi 1 tiếng
# Tham khảo: https://crontab.guru/
CRON_SCHEDULE="0 * * * *"

# --- Bootstrap ---
# Đặt thành "true" để bỏ qua auto-scrape khi khởi động (hữu ích cho testing)
SKIP_BOOTSTRAP_JOBS=false

# --- Scraper URLs (tùy chọn, dùng khi cần override) ---
PETROLIMEX_URL=https://www.petrolimex.com.vn/index.html
PVOIL_URL=https://www.pvoil.com.vn/tin-gia-xang-dau
MIPEC_URL=https://www.mipec.com.vn/pages/gia-xang-dau-ban-le
WEBGIA_URL=https://webgia.com/gia-xang-dau/petrolimex/
GXHN_URL=https://giaxanghomnay.com

# --- Gold price API ---
GOLD_API_URL=https://www.vang.today/api/prices
GOLD_CACHE_TTL_SECONDS=300
