{
  "name": "petrolimex-fuel-api",
  "version": "1.0.0",
  "description": "Minimal API/data service for Vietnamese fuel prices and gold prices.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon --ignore cache.json --ignore logs/** index.js",
    "scrape": "node services/scraper.js",
    "test": "node --test tests/*.test.js",
    "browser:install": "npx playwright install chromium"
  },
