{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm --prefix \"gia thi truong xang dau/vietfuel-api/backend\" ci",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "gia thi truong xang dau/{index.html,style.css,script.js,vietfuel-api/cache.json,vietfuel-api/backend/cache.json,vietfuel-api/backend/data/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
